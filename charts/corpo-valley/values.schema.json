{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/corpo-valley/corpo-valley-chart/values.schema.json",
  "title": "Corpo Valley chart values",
  "type": "object",
  "additionalProperties": false,
  "required": ["role", "domain", "namespacePrefix", "image"],
  "properties": {
    "role": {
      "type": "string",
      "enum": ["all-in-one", "platform", "tenants"],
      "default": "all-in-one"
    },
    "domain": {
      "type": "string",
      "pattern": "^[a-z0-9]([a-z0-9-]*[a-z0-9])?(\\.[a-z0-9]([a-z0-9-]*[a-z0-9])?)+$"
    },
    "hosts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "portal":           { "type": "string" },
        "auth":             { "type": "string" },
        "oauth":            { "type": "string" },
        "gitea":            { "type": "string" },
        "mcp":              { "type": "string" },
        "cooldeps":         { "type": "string" },
        "projectsWildcard": { "type": "string" },
        "oathkeeperWildcard": { "type": "boolean" }
      }
    },
    "namespacePrefix": {
      "type": "string",
      "pattern": "^[a-z]([a-z0-9-]*-)$",
      "description": "Must be lowercase, end in '-'. Examples: cv-, acme-, beta-"
    },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "required": ["registry", "prefix"],
      "properties": {
        "registry":   { "type": "string" },
        "prefix":     { "type": "string" },
        "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] },
        "defaultTag": { "type": "string" },
        "pullSecret": { "type": "string" },
        "tags": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "git": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "platformRepoUrl":    { "type": "string" },
        "platformRepoBranch": { "type": "string" }
      }
    },
    "cloudflare": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tunnelName": { "type": "string" },
        "tunnelId":   { "type": "string", "description": "UUID from `cloudflared tunnel create`. Required at install time." }
      }
    },
    "email": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "fromAddress": { "type": "string" },
        "fromName":    { "type": "string" }
      }
    },
    "auth": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "google": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "allowedDomains": {
              "type": "array",
              "items": {
                "type": "string",
                "pattern": "^[a-z0-9]([a-z0-9-]*[a-z0-9])?(\\.[a-z0-9]([a-z0-9-]*[a-z0-9])?)+$"
              },
              "description": "Google Workspace domains (hd claim) allowed to sign in/up. Required (non-empty) when enabled."
            }
          }
        }
      }
    },
    "storage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "className":            { "type": "string" },
        "oryPostgresClassName": { "type": "string", "description": "StorageClass for the ory-postgres volumeClaimTemplate. Unset inherits storage.className; set-but-empty omits the field (cluster default binds). Use when adopting a pre-chart ory-postgres whose live volumes have an empty/different (immutable) storageClassName." },
        "oryPostgres": { "type": "string" },
        "gitea":       { "type": "string" },
        "registry":    { "type": "string" },
        "cooldeps":    { "type": "string" }
      }
    },
    "tenant": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "memory": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "max":             { "type": "string", "description": "Per-project max memory usage (ResourceQuota limits.memory). Portal receives it as CV_MAX_MEMORY." },
            "maxRequests":     { "type": "string", "description": "Per-project scheduled memory floor (ResourceQuota requests.memory → CV_MAX_MEMORY_REQUESTS)." },
            "maxPerContainer": { "type": "string", "description": "Ceiling any single container may request (LimitRange max.memory → CV_MAX_MEMORY_PER_CONTAINER)." },
            "default":         { "type": "string", "description": "Default memory limit for a new/undeclared container (LimitRange default → CV_DEFAULT_MEMORY)." },
            "defaultRequest":  { "type": "string", "description": "Default memory request for a new/undeclared container (LimitRange defaultRequest → CV_DEFAULT_MEMORY_REQUEST)." }
          }
        },
        "cpu": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "max":             { "type": "string", "description": "Per-project max CPU (ResourceQuota limits.cpu → CV_MAX_CPU)." },
            "maxRequests":     { "type": "string", "description": "Per-project scheduled CPU floor (ResourceQuota requests.cpu → CV_MAX_CPU_REQUESTS)." },
            "maxPerContainer": { "type": "string", "description": "Ceiling any single container may request (LimitRange max.cpu → CV_MAX_CPU_PER_CONTAINER)." },
            "default":         { "type": "string", "description": "Default CPU limit for a new/undeclared container (LimitRange default → CV_DEFAULT_CPU)." },
            "defaultRequest":  { "type": "string", "description": "Default CPU request for a new/undeclared container (LimitRange defaultRequest → CV_DEFAULT_CPU_REQUEST)." }
          }
        },
        "storage": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "default":      { "type": "string", "description": "Size of each capability data volume at provision (volumeClaimTemplate → CV_DEFAULT_STORAGE)." },
            "maxPerVolume": { "type": "string", "description": "Per-volume admission cap — drives the cv-projects-*-bounds VAPs and the portal's grow pre-check (→ CV_MAX_PVC_SIZE)." },
            "maxTotal":     { "type": "string", "description": "Per-namespace total storage (ResourceQuota requests.storage, sum of all PVCs → CV_MAX_STORAGE)." }
          }
        },
        "pods": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "max": { "type": "string", "description": "Max pods per project namespace (ResourceQuota pods → CV_MAX_PODS)." }
          }
        },
        "pvcs": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "max": { "type": "string", "description": "Max PersistentVolumeClaims per project namespace (ResourceQuota persistentvolumeclaims → CV_MAX_PVCS)." }
          }
        },
        "capabilities": {
          "type": "object",
          "additionalProperties": false,
          "description": "Per-project stateful capabilities, configured uniformly. Each image is stamped into the StatefulSet AND pinned by that capability's VAP.",
          "properties": {
            "postgres": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "image": { "type": "string", "description": "Pinned Postgres image (→ CV_POSTGRES_IMAGE + cv-projects-postgres-bounds VAP pin)." }
              }
            },
            "garage": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "image": { "type": "string", "description": "Pinned Garage image (→ CV_GARAGE_IMAGE + cv-projects-garage-bounds VAP pin)." }
              }
            }
          }
        }
      }
    },
    "ingress": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "className":         { "type": "string" },
        "commonAnnotations": { "type": "object" }
      }
    },
    "cluster": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "podCIDR":     { "type": "string" },
        "serviceCIDR": { "type": "string" },
        "nodeCIDR":    { "type": "string" },
        "sealedSecretsControllerUrl": { "type": "string" },
        "sealedSecretsCertSha256": {
          "type": "string",
          "pattern": "^([0-9a-f]{64})?$",
          "description": "SPKI sha256 pin of the sealed-secrets controller cert (lowercase hex, from scripts/print-cert-pin.sh). Empty omits the pin env, which disables project-secret sealing in production images."
        }
      }
    },
    "resources": {
      "type": "object",
      "description": "Per platform-component CPU/memory. Keyed by component name; each value is a requests/limits pair.",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "requests": {
            "type": "object",
            "additionalProperties": false,
            "properties": { "cpu": { "type": "string" }, "memory": { "type": "string" } }
          },
          "limits": {
            "type": "object",
            "additionalProperties": false,
            "properties": { "cpu": { "type": ["string", "integer"] }, "memory": { "type": "string" } }
          }
        }
      }
    },
    "scale": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "kratos":      { "type": "integer", "minimum": 1 },
        "hydra":       { "type": "integer", "minimum": 1 },
        "keto":        { "type": "integer", "minimum": 1 },
        "oathkeeper":  { "type": "integer", "minimum": 1 },
        "portal":      { "type": "integer", "minimum": 1 },
        "mcpGateway":  { "type": "integer", "minimum": 1 },
        "giteaRunner": { "type": "integer", "minimum": 1 },
        "cloudflared": { "type": "integer", "minimum": 1 }
      }
    },
    "argocd": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "projectsArgocd": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled":    { "type": "boolean" },
            "nsLogical":  { "type": "string" },
            "appProject": { "type": "string" }
          }
        },
        "trustedClientIds":     { "type": "string" },
        "disableSubmoduleInit": { "type": "boolean" }
      }
    },
    "mcp": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "publicUrl":       { "type": "string" },
        "enforceAudience": { "type": "boolean" },
        "denyClientIds":   { "type": "string" }
      }
    },
    "cooldeps": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled":          { "type": "boolean" },
        "publicIngress":    { "type": "boolean" },
        "logLevel":         { "type": "string", "enum": ["debug", "info", "warn", "error"] },
        "statusEnabled":    { "type": "boolean" },
        "artifactMaxBytes": { "type": "string" },
        "policy":           { "type": "object", "description": "Passed through verbatim to cooldeps' policy: config block." }
      }
    },
    "backups": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" }
      }
    }
  }
}
